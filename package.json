{
  "name": "globaly-i18n",
  "version": "1.1.0",
  "description": "Lightweight internationalization (i18n) library for JavaScript and TypeScript applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/RounakSharma19/globaly-i18n.git"
  },
  "homepage": "https://github.com/RounakSharma19/globaly-i18n",
  "bugs": {
    "url": "https://github.com/RounakSharma19/globaly-i18n/issues"
  },
 
  "bin": {
    "globaly-i18n-extract": "./dist/cli/extract.js",
    "globaly-i18n-translate": "./dist/cli/translate.js"
  },
  "scripts": {
   "build": "tsup src/index.ts --format esm,cjs --minify --clean && tsup src/cli/extract.ts src/cli/translate.ts --format esm,cjs --minify --out-dir dist/cli",
    "dev": "tsup src/index.ts --watch",
    "test": "vitest"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "translation",
    "localization",
    "javascript-i18n",
    "typescript-i18n",
    "node-i18n",
    "frontend-i18n",
    "backend-i18n",
    "web-i18n",
    "dynamic-translation",
    "language-translation",
    "language-switching",
    "translation-library",
    "localization-library",
    "i18n-library",
    "multi-language",
    "pluralization",
    "interpolation",
    "ssr-i18n",
    "framework-agnostic",
    "react-i18n",
    "translation-tool",
    "globalization-library"
  ],
  "author": "Rounak Sharma",
  "license": "MIT",
  "peerDependencies": {
    "react": "^19.2.4"
  },
  "dependencies": {
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
